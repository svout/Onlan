{
  "printWidth": 120,
  "tabWidth": 4,
  "trailingComma": "es5",
  "semi": true,
  "singleQuote": true,
  "bracketSpacing": true,
  "arrowParens": "always",
  "jsxSingleQuote": false,
  "bracketSameLine": false,
  "endOfLine": "lf",
  "proseWrap": "always",
  "tailwindStylesheet": "./src/styles/index.css",
  "plugins": [
    "prettier-plugin-tailwindcss"
  ]
}

